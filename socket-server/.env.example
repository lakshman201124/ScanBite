# Socket server environment variables
# Copy to .env and fill in values before deploying.

# Sentry DSN for error tracking (get from sentry.io → Project Settings → Client Keys)
SENTRY_DSN=

# Node environment
NODE_ENV=production

# Port to listen on (default 3001)
PORT=3001

# Redis URL for the pub/sub adapter (Upstash: use the ioredis-compatible URL)
REDIS_URL=redis://default:<password>@<host>:<port>

# Auth secret — must match NEXTAUTH_SECRET in the Next.js app (same key, min 32 chars)
AUTH_SECRET=

# Comma-separated list of allowed CORS origins (your Next.js app URL)
ALLOWED_ORIGINS=https://yourdomain.com
